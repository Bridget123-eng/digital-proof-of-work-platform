NODE_ENV=development
PORT=5000

# Database
MONGO_URI=mongodb://127.0.0.1:27017/digital-proof-of-work
# DNS_SERVERS=8.8.8.8,1.1.1.1

# Auth
JWT_SECRET=replace-with-a-long-random-secret
ADMIN_EMAILS=admin@example.com

# Frontend URLs
# Use your deployed frontend URL in production, for example:
# APP_ORIGIN=https://your-frontend.example.com
APP_ORIGIN=http://localhost:5173
# Optional override for password reset links. Set this in production if APP_ORIGIN is not your frontend URL.
# RESET_PASSWORD_URL_BASE=https://your-frontend.example.com

# Email delivery: prefer SMTP_* in production.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=apikey-or-username
# SMTP_PASS=secret
# EMAIL_FROM=no-reply@example.com

# Simple Gmail-style fallback for development.
# EMAIL_SERVICE=gmail
# EMAIL_USER=your-address@gmail.com
# EMAIL_PASS=your-app-password
