NODE_ENV=production
PORT=5000

# Frontend / CORS
FRONTEND_URL=https://your-vercel-frontend.vercel.app
APP_ORIGIN=https://your-vercel-frontend.vercel.app

# Required: MongoDB Atlas
# If your password has @ # $ % : / ? & =, URL-encode it before pasting it here.
# Example: my@pass#123 -> my%40pass%23123
MONGO_URI=mongodb+srv://username:encodedPassword@cluster.mongodb.net/dbname?retryWrites=true&w=majority

# Required: JWT
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# OTP / reset code lifetime
OTP_EXPIRES_IN_MINUTES=10

# Optional: Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Optional: SMTP email
# If these are missing, Render deployment still starts and /api/health works.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_16_digit_gmail_app_password_without_spaces
SMTP_FROM=Auth App <your_email@gmail.com>
